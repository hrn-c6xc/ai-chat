{
  "openapi": "3.0.3",
  "info": {
    "title": "HRN AIClient API",
    "version": "1.0.3",
    "description": "Volledige OpenAPI spec voor de HRN AIClient JavaScript bibliotheek."
  },
  "servers": [
    {
      "url": "https://gen.pollinations.ai/v1",
      "description": "Standaard AI endpoint"
    }
  ],
  "paths": {
    "/chat/completions": {
      "post": {
        "summary": "Genereer AI tekst",
        "description": "Gebruik `AIClient.generate()` met `type='text'`.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "apiKey": { "type": "string", "description": "Je API sleutel" },
                  "model": { "type": "string", "example": "flux" },
                  "systemPrompt": { "type": "string", "example": "You are a helpful assistant." },
                  "history": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "role": { "type": "string", "enum": ["system","user","assistant"] },
                        "content": { "type": "string" }
                      },
                      "required": ["role","content"]
                    }
                  },
                  "seed": { "type": "integer", "example": 123456789 },
                  "timeout": { "type": "integer", "example": 30000 },
                  "retry": { "type": "boolean", "example": true },
                  "retryAttempts": { "type": "integer", "example": 2 },
                  "retryDelay": { "type": "integer", "example": 1000 },
                  "prompt": { "type": "string" }
                },
                "required": ["apiKey","model","prompt"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "AI tekst response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "choices": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "message": {
                            "type": "object",
                            "properties": {
                              "role": { "type": "string" },
                              "content": { "type": "string" }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "default": { "description": "Fout", "content": { "application/json": { "schema": { "type": "object" } } } }
        }
      }
    },
    "/images/generations": {
      "post": {
        "summary": "Genereer AI afbeelding",
        "description": "Gebruik `AIClient.generate()` met `type='image'`.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "apiKey": { "type": "string", "description": "Je API sleutel" },
                  "model": { "type": "string", "example": "flux" },
                  "prompt": { "type": "string" },
                  "width": { "type": "integer", "example": 1024 },
                  "height": { "type": "integer", "example": 1024 },
                  "nologo": { "type": "boolean", "example": true },
                  "response_format": { "type": "string", "example": "b64_json" },
                  "seed": { "type": "integer", "example": 123456789 },
                  "timeout": { "type": "integer", "example": 30000 },
                  "retry": { "type": "boolean", "example": true },
                  "retryAttempts": { "type": "integer", "example": 2 },
                  "retryDelay": { "type": "integer", "example": 1000 }
                },
                "required": ["apiKey","model","prompt","width","height","response_format"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "AI afbeelding response (Base64 PNG)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "b64_json": { "type": "string", "description": "Base64 encoded PNG" }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "default": { "description": "Fout", "content": { "application/json": { "schema": { "type": "object" } } } }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "API Key"
      }
    }
  },
  "security": [
    { "BearerAuth": [] }
  ]
}
